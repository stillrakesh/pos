{
  "name": "restaurant-pos",
  "productName": "Restaurant POS",
  "version": "1.0.0",
  "description": "Restaurant POS Desktop App",
  "author": "Tyde Cafe",
  "private": true,
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite --host --port 5175",
    "server": "node server/index.js",
    "dev:all": "concurrently \"vite --host --port 5175\" \"node server/index.js\"",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "desktop": "electron .",
    "pack": "electron-builder --dir",
    "dist": "node scripts/copy-node.js && electron-builder"
  },
  "build": {
    "appId": "com.tydepos.app",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "extraResources": [
        {
          "from": "bundled-node.exe",
          "to": "bundled-node.exe"
        }
      ]
    },
    "mac": {
      "target": "dmg",
      "identity": null,
      "minimumSystemVersion": "10.12.0",
      "extraResources": [
        {
          "from": "bundled-node-mac",
          "to": "bundled-node"
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": false
    },
    "files": [
      "dist/**/*",
      "frontend/captain/dist/**/*",
      "server/**/*",
      "electron/**/*",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "stillrakesh",
        "repo": "pos"
      }
    ]
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "electron-updater": "^6.8.3",
    "express": "^5.1.0",
    "framer-motion": "^12.34.3",
    "idb-keyval": "^6.2.2",
    "lucide-react": "^0.575.0",
    "playwright": "^1.59.1",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-is": "^19.2.5",
    "recharts": "^3.7.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sql.js": "^1.12.0",
    "tailwind-merge": "^3.5.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^41.2.2",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "vite": "^7.3.1",
    "wait-on": "^9.0.5"
  }
}
